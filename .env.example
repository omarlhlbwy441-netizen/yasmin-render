# Yasmin Al-Hob - Environment Variables
NODE_ENV=production
PORT=3005
NEXTAUTH_URL=https://yasmin-al-hob-your-service.onrender.com
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-long

# Database
DATABASE_URL=postgresql://user:password@host:5432/yasmin_db

# Redis
REDIS_URL=redis://user:password@host:6379

# Authentication (Clerk)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# AI
GEMINI_API_KEY=your-gemini-api-key

# Monitoring
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info
